{
  "extends": "./base.json",
  "compilerOptions": {
    "declaration": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "isolatedModules": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "removeComments": true,
    "resolvePackageJsonExports": true,
    "sourceMap": true,
    "target": "ES2023"
  }
}